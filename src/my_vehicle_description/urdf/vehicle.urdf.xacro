<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro"
       name="my_vehicle">

    <xacro:include filename="$(find my_vehicle_description)/urdf/chassis.xacro"/>
    <xacro:include filename="$(find my_vehicle_description)/urdf/wheels.xacro"/>
    <xacro:include filename="$(find my_vehicle_description)/urdf/sensors.xacro"/>
    <xacro:include filename="$(find my_vehicle_description)/urdf/gazebo.xacro"/>

</robot>
